<?xml version='1.0' encoding='utf-8'?>
<!-- https://stackoverflow.com/questions/79470924/does-drake-have-an-equivalent-of-mujoco-mocap-bodies -->
<sdf version="1.9" xmlns:drake="http://drake.mit.edu">
<model name="rope_holder">
    <pose>0 0 0 0 0 0</pose>
    <joint name="translate_joint_x" type="prismatic">
      <parent>world</parent>
      <child>false_0</child>
      <axis>
        <xyz expressed_in="__model__">1 0 0</xyz>
      </axis>
      <drake:controller_gains p='1000000.0' d='1000.0' />
    </joint>
    <link name="false_0">
      <inertial>
        <inertia>
          <ixx>0.0001</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.0001</iyy>
          <iyz>0</iyz>
          <izz>0.0001</izz>
        </inertia>
        <mass>0.09</mass>
      </inertial>
    </link>
    <joint name="translate_joint_z" type="prismatic">
      <parent>false_0</parent>
      <child>false_1</child>
      <axis>
        <xyz expressed_in="__model__">0 0 1</xyz>
      </axis>
      <drake:controller_gains p='1000000.0' d='1000.0' />
    </joint>
    <link name="false_1">
      <inertial>
        <inertia>
          <ixx>0.0001</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.0001</iyy>
          <iyz>0</iyz>
          <izz>0.0001</izz>
        </inertia>
        <mass>0.09</mass>
      </inertial>
    </link>
    <joint name="rotate_joint" type="revolute">
      <parent>false_1</parent>
      <child>rope_holder_body</child>
      <axis>
        <xyz expressed_in="false_1">0 -1 0</xyz>
      </axis>
      <drake:controller_gains p='10000000.0' d='1000.0' />
    </joint>

    <link name="rope_holder_body">
      <inertial>
        <inertia>
          <ixx>0.0001</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.0001</iyy>
          <iyz>0</iyz>
          <izz>0.0001</izz>
        </inertia>
        <mass>0.09</mass>
      </inertial>
      <!-- <collision name="rope_holder_body_collision">
        <pose degrees="True" relative_to="rope_holder_body">0.075 0 0 0 90 0</pose>
        <geometry>
          <cylinder>
            <radius>0.00675</radius>
            <length>0.15</length>
          </cylinder>
        </geometry>
      </collision> -->
      <visual name="rope_holder_body_visual">
      <pose degrees="True" relative_to="rope_holder_body">0 0 -0.075 0 0 0</pose>
      <!-- <pose degrees="True" relative_to="rope_holder_center">0 0 0 0 0 90</pose> -->
        <!-- <geometry>
          <mesh>
            <scale>1 1 1</scale>
            <uri>package://flying_knot_models/rope/meshes/rope_holder_body.obj</uri>
          </mesh>
        </geometry> -->
        <geometry>
          <cylinder>
            <radius>0.00675</radius>
            <length>0.15</length>
          </cylinder>
        </geometry>
        <material>
          <diffuse>0 0 0 1</diffuse>
        </material>
      </visual>
    </link>
    <frame name="rope_holder_center" attached_to="rope_holder_body">
      <pose degrees="True" relative_to="rope_holder_body">0 0 0.02 0 0 0</pose>
    </frame>
    <!-- <frame name="rope_holder_center" attached_to="rope_holder_body">
      <pose degrees="True" relative_to="rope_holder_body">-0.007 0 -0.0105 3 1 0</pose>
    </frame> -->
    <frame name="rope_holder_tip" attached_to="rope_holder_body">
      <pose degrees="True">0 0 -0.15 0 90 0</pose>
    </frame>
    <frame name="rope_start_frame" attached_to="rope_holder_body">
      <pose degrees="True">0 0 -0.14 0 90 0</pose>
    </frame>
  </model>
</sdf>